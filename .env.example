# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./referidos.db
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/referidos

# JWT
SECRET_KEY=change-this-to-a-very-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin seed
ADMIN_EMAIL=admin@egp.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Admin
ADMIN_LAST_NAME=EGP

# App
APP_NAME=EGP Referidos
BASE_URL=http://localhost:8000

# Email (SMTP)
EMAILS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=EGP Referidos <noreply@egp.com>

# WhatsApp
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=ultramsg   # "ultramsg" (recomendado) o "meta"

# --- Opción 1: UltraMsg (sin aprobación de Meta, solo escanear QR) ---
# 1. Crea cuenta en https://ultramsg.com
# 2. Crea una instancia → escanea el QR con tu WhatsApp Business
# 3. Copia el Instance ID y el Token
WHATSAPP_INSTANCE_ID=        # ej: instance12345
WHATSAPP_INSTANCE_TOKEN=     # ej: abc123token

# --- Opción 2: Meta WhatsApp Business Cloud API ---
WHATSAPP_META_TOKEN=         # Token de acceso permanente de Meta
WHATSAPP_META_PHONE_ID=      # ID del número (ej: 123456789012345)
